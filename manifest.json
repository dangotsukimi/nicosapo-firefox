{
  "manifest_version": 2,
  "name": "ニコ生自動入場 (Auto Enter)",
  "version": "1.0",
  "description": "ニコニコ生放送の特定のコミュニティ・チャンネルの生放送が始まったら、自動的にブラウザで開きます。",
  "permissions": [
    "storage",
    "tabs",
    "alarms",
    "notifications",
    "https://live2.nicovideo.jp/*",
    "https://live.nicovideo.jp/*",
    "https://com.nicovideo.jp/*",
    "https://ch.nicovideo.jp/*",
    "https://www.nicovideo.jp/*"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "browser_action": {
    "default_icon": "images/icon.png",
    "default_title": "自動入場設定"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "icons": {
    "128": "images/icon.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "niconama-auto-enter@dango.com",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
